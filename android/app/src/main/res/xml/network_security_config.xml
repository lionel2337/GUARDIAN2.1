<?xml version="1.0" encoding="utf-8"?>
<!-- Network security config: Allow cleartext for local development.
     In production, remove cleartextTrafficPermitted. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Allow Supabase and OSM tile servers -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">openstreetmap.org</domain>
        <domain includeSubdomains="true">cartocdn.com</domain>
    </domain-config>
</network-security-config>
